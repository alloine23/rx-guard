generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

enum UserRole {
  superadmin
  admin
  doctor
  pharmacist
  patient
}

enum InstitutionType {
  hospital
  pharmacy
}

enum OcrStatus {
  pending
  processing
  done
  failed
}

enum OcrEngine {
  traditional
  llm
  llm_direct
}

enum SignatureStatus {
  unsigned
  signed
}

enum ConsentStatus {
  pending
  approved
  rejected
  revoked
}

enum VerificationStatus {
  verified
  dispensed
  rejected
}

model User {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String    @unique @db.VarChar(255)
  passwordHash         String    @map("password_hash")
  role                 UserRole
  institutionId        String?   @map("institution_id") @db.Uuid
  isActive             Boolean   @default(true) @map("is_active")
  forcePasswordChange  Boolean   @default(false) @map("force_password_change")
  resetToken           String?   @map("reset_token")
  resetTokenExpiry     DateTime? @map("reset_token_expiry")
  createdAt            DateTime  @default(now()) @map("created_at")

  institution          Institution?   @relation("UserInstitution", fields: [institutionId], references: [id], onDelete: SetNull)
  patientProfile       Patient?       @relation("PatientUser")
  registeredPatients   Patient[]      @relation("RegisteredBy")
  uploadedRecords      MedicalRecord[]
  approvedConsents     Consent[]      @relation("ConsentApprover")
  verifications        PrescriptionVerification[]
  doctorKeyPair        DoctorKeyPair?  @relation("DoctorKeyPair")
  signedRecords        MedicalRecord[] @relation("SignedRecords")
  auditLogs            AuditLog[]
  notifications        Notification[]

  @@map("users")
}

model Institution {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String          @db.VarChar(255)
  type                   InstitutionType
  location               String?
  credentialsUrl         String?         @map("credentials_url")
  inChargePharmacistId   String?         @map("in_charge_pharmacist_id") @db.Uuid
  createdAt              DateTime        @default(now()) @map("created_at")

  users                  User[]          @relation("UserInstitution")
  records                MedicalRecord[]
  patientConsents        Consent[]       @relation("HospitalConsent")

  @@map("institutions")
}

model Patient {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientCode   String   @unique @map("patient_code") @db.VarChar(50)
  userId        String   @unique @map("user_id") @db.Uuid
  registeredBy  String   @map("registered_by") @db.Uuid
  fullName      String   @map("full_name") @db.VarChar(255)
  dateOfBirth   String   @map("date_of_birth")
  phone         String?
  photoUrl      String?  @map("photo_url")
  email         String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation("PatientUser", fields: [userId], references: [id], onDelete: Cascade)
  doctor        User     @relation("RegisteredBy", fields: [registeredBy], references: [id], onDelete: Restrict)
  records       MedicalRecord[]
  consents      Consent[]

  @@map("patients")
}

model MedicalRecord {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String     @map("patient_id") @db.Uuid
  uploadedBy    String     @map("uploaded_by") @db.Uuid
  institutionId String     @map("institution_id") @db.Uuid
  imageUrl      String     @map("image_url")
  ocrStatus     OcrStatus  @default(pending) @map("ocr_status")
  ocrEngine     OcrEngine? @map("ocr_engine")
  ocrData       Json?      @map("ocr_data")
  ocrConfidence Float?     @map("ocr_confidence")
  recordType    String?    @map("record_type") @db.VarChar(50)
  isDuplicate   Boolean    @default(false) @map("is_duplicate")
  createdAt     DateTime   @default(now()) @map("created_at")

  signatureStatus  SignatureStatus @default(unsigned) @map("signature_status")
  digitalSignature String?         @map("digital_signature")
  signedAt         DateTime?       @map("signed_at")
  signedById       String?         @map("signed_by_id") @db.Uuid
  signedDataHash   String?         @map("signed_data_hash") @db.VarChar(64)
  verifyToken      String?         @map("verify_token") @db.VarChar(32)

  patient       Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploader      User       @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  signedBy      User?       @relation("SignedRecords", fields: [signedById], references: [id])
  imageHash     ImageHash?
  verifications PrescriptionVerification[]

  @@map("medical_records")
}

model Consent {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String        @map("patient_id") @db.Uuid
  hospitalId  String        @map("hospital_id") @db.Uuid
  approvedBy  String?       @map("approved_by") @db.Uuid
  status      ConsentStatus @default(pending)
  grantedAt   DateTime?     @map("granted_at")
  revokedAt        DateTime?     @map("revoked_at")
  expiresAt        DateTime?     @map("expires_at")
  rejectionReason  String?       @map("rejection_reason")
  createdAt        DateTime      @default(now()) @map("created_at")

  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  hospital    Institution   @relation("HospitalConsent", fields: [hospitalId], references: [id], onDelete: Cascade)
  approver    User?         @relation("ConsentApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@map("consents")
}

model PrescriptionVerification {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId        String             @map("record_id") @db.Uuid
  pharmacistId    String             @map("pharmacist_id") @db.Uuid
  status          VerificationStatus @default(verified)
  rejectionReason String?            @map("rejection_reason")
  verifiedAt      DateTime           @default(now()) @map("verified_at")
  dispensedAt     DateTime?          @map("dispensed_at")

  record          MedicalRecord      @relation(fields: [recordId], references: [id], onDelete: Cascade)
  pharmacist      User               @relation(fields: [pharmacistId], references: [id], onDelete: Restrict)

  @@map("prescription_verifications")
}

/// Stores pHash and ViT embedding for deduplication
model ImageHash {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId  String   @unique @map("record_id") @db.Uuid
  phash     String?  @db.VarChar(64)
  crhash    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  record    MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  // NOTE: `embedding VECTOR(512)` is managed via raw migration — Prisma does not
  // natively model pgvector columns. See migration in prisma/migrations/.

  @@map("image_hashes")
}

model DoctorKeyPair {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  publicKey           String   @map("public_key") @db.VarChar(128)
  encryptedPrivateKey String   @map("encrypted_private_key")
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation("DoctorKeyPair", fields: [userId], references: [id], onDelete: Cascade)

  @@map("doctor_key_pairs")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String   @db.VarChar(100)
  resourceType String?  @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.Uuid
  ipAddress    String?  @map("ip_address")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  payload   Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
